        "import pandas as pd\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer as Vectorizer\n",
        "import re\n",
        "df=pd.read_csv(\"/content/df.csv\")\n",
        "train_df=pd.read_csv(\"/content/train_df.csv\")\n",
        "valid_df=pd.read_csv(\"/content/valid_df.csv\")\n",
        "\n",
        "full_df=pd.concat([train_df,df])\n",
        "full_df = full_df.dropna(subset=[\"clean_text\"])\n",
        "full_df = full_df.drop_duplicates(subset=[\"clean_text\", \"sentiment\"])\n",
        "\n",
        "\n",
        "Vectorizer = Vectorizer(stop_words=\"english\")\n",
        "\n",
        "\n",
        "def clean_text(text):\n",
        "  text=text.lower()\n",
        "  text=re.sub(r\"[^\\w\\s]\", \" \", text)\n",
        "  text = \" \".join(text.split())\n",
        "  return text\n",
        "full_df[\"clean_text\"]=full_df[\"clean_text\"].apply(clean_text)\n",
        "full_df[\"sentiment\"]=full_df[\"sentiment\"].str.lower()\n",
        "\n",
        "full_df[\"sentiment\"] = full_df[\"sentiment\"].replace({\n",
        "    \"highly recommended\": \"positive\",\n",
        "    \"very satisfied\": \"positive\",\n",
        "    \"could be better\": \"neutral\",\n",
        "    \"not impressed at all\": \"negative\",\n",
        "    \"very poor design\": \"negative\",\n",
        "    \"i am impressed\": \"positive\",\n",
        "    \"i am not satisfied\": \"negative\",\n",
        "    \"meh it's alright\": \"neutral\",\n",
        "    \"i am confused\":\"negative\"\n",
        "})\n",
        "\n",
        "\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.svm import LinearSVC\n",
        "from sklearn.naive_bayes import MultinomialNB\n",
        "from sklearn.metrics import accuracy_score,confusion_matrix,classification_report\n",
        "\n",
        "\n",
        "x = Vectorizer.fit_transform(full_df[\"clean_text\"])\n",
        "y = full_df[\"sentiment\"]\n",
        "\n",
        "x_train, x_temp, y_train, y_temp = train_test_split(\n",
        "    x, y, test_size=0.3, random_state=42\n",
